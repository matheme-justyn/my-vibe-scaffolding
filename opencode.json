{
  "$schema": "https://opencode.ai/config.json",
  "share": "auto",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "provider": {
    "anthropic": {
      "options": {
        "timeout": 900000
      }
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["bunx", "@modelcontextprotocol/server-filesystem", "."]
    },
    "git": {
      "type": "local",
      "command": ["uv", "tool", "run", "mcp-server-git", "--repository", "."]
    },
    "memory": {
      "type": "local",
      "command": ["bunx", "@modelcontextprotocol/server-memory"]
    },
    "github": {
      "type": "local",
      "command": ["bunx", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
