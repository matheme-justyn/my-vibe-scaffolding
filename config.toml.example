# Vibe Scaffolding Configuration
# Copy this file to config.toml and customize for your workspace

# ==============================================================================
# Internationalization (i18n) - Natural Language Support
# ==============================================================================
# Uses BCP 47 language tags (RFC 5646)
# See: https://www.rfc-editor.org/rfc/rfc5646.html
#
# Available locales:
#   - en-US: English (United States) - Default, always available in Git
#   - zh-TW: Traditional Chinese (Taiwan) - Available in Git
#   - zh-HK: Traditional Chinese (Hong Kong) - Future
#   - zh-CN: Simplified Chinese (China) - Future
#   - ja-JP: Japanese (Japan) - Future
#   - en-GB: English (United Kingdom) - Future

[i18n]
# Your preferred natural language for documentation and templates
# This determines which i18n/locales/{lang}/ directory to use for:
#   - AGENTS.md coding conventions and commit message format
#   - README.md section descriptions
#   - GitHub issue/PR templates
#   - ADR (Architecture Decision Record) templates
primary_locale = "zh-TW"

# Fallback language if translation is missing
# Should always be "en-US" (the base language committed to Git)
fallback_locale = "en-US"

# Which locales to commit to Git repository
# Recommended: Only commit en-US (base) and your team's primary language
# Other locales can be generated locally or added later
commit_locales = ["en-US", "zh-TW"]

# Translation workflow settings (if you're doing translation work)
[i18n.translation]
# Enable translation mode (shows missing keys, validates completeness)
enabled = false

# Source language for translation work
source_lang = "zh-TW"

# Target languages you're working on
target_langs = ["en-US", "ja-JP"]

# Validation: ensure all keys exist in all enabled locales
strict_validation = false

# README language strategy
# Controls how README files are generated and organized
[i18n.readme]
# Strategy options:
#   - "separate": Separate files (README.md in primary_locale, README.{lang}.md for others)
#                 Example: README.md (zh-TW), README.en-US.md, README.ja-JP.md
#                 Recommended for: Professional projects, 3+ languages, cleaner structure
#
#   - "bilingual": Single README.md with both languages side-by-side
#                  Format: 中文 | English in same file (headers, paragraphs, tables)
#                  Recommended for: Small projects, 2 languages max
#
#   - "primary_only": Single README.md in primary_locale only, no translations
#                     Recommended for: Internal projects, single team language
strategy = "separate"

# When strategy = "separate":
# - README.md contains content in primary_locale
# - Additional files: README.en-US.md, README.zh-TW.md, etc. for each commit_locales
# - Language switcher added at top of each README
#
# When strategy = "bilingual":
# - Single README.md with bilingual content (follows .template/docs/README_BILINGUAL_FORMAT.md)
# - Primary language appears first, then English (or other language)
#
# When strategy = "primary_only":
# - Only README.md in primary_locale, no additional language files

# ==============================================================================
# Programming Languages Configuration (Future)
# ==============================================================================
# Preferences for programming language modules in languages/ directory
# Currently manual - copy configs from languages/{lang}/ as needed

[languages]
# Your primary programming languages for this project
# This is informational only - helps document the project's tech stack
primary = []  # e.g., ["go", "python", "typescript"]

# Whether to include language-specific .gitignore patterns by default
# Currently manual - use: cat languages/{lang}/.gitignore >> .gitignore
auto_merge_gitignore = false

# ==============================================================================
# Project Metadata (Future)
# ==============================================================================
# Project information that could be used by tools or documentation generators

[project]
# Working mode: 'scaffolding' or 'project'
#
# - scaffolding: You're developing this scaffolding template itself
#   → Scaffolding ADRs: .template/docs/adr/
#   → Scaffolding scripts: .template/scripts/
#   → Scaffolding assets: .template/assets/
#   → Keep root docs/, scripts/, assets/ empty or minimal
#
# - project: You're using this scaffolding for your project
#   → Project ADRs: docs/adr/
#   → Project scripts: scripts/
#   → Project assets: assets/
#   → .template/ contains reference examples only
mode = "project"  # Change to 'scaffolding' if developing the scaffolding itself

# Project metadata
# name = "my-project"
# description = "Project description"
# version = "0.1.0"


# ==============================================================================
# OpenCode Stability & Workflow
# ==============================================================================
# Configuration for OpenCode session management and stability tools

[opencode]
# Enable OpenCode stability features
enabled = true

[opencode.cleanup]
# Smart session cleanup - triggers when any condition is met
max_sessions = 20              # Sessions 超過此數量 → 觸發清理
max_db_size_mb = 50            # 資料庫超過 MB → 觸發清理
max_startup_sec = 10           # 啟動超過秒數 → 觸發清理

# Retention policy
keep_sessions = 15             # 最多保留 N 個活躍 sessions
min_days_before_archive = 7    # N 天未訪問才考慮 archive

# Aggressive mode (當機頻率高時啟用)
aggressive_mode = false        # true = 更激進清理
aggressive_keep = 10           # 激進模式保留 sessions 數
aggressive_min_days = 3        # 激進模式最小天數

[opencode.monitor]
# Stability monitoring thresholds
crash_threshold = 2            # 一天內崩潰 N 次算異常
session_duration_min = 180     # 正常 session 應持續分鐘數（3 小時）

# Memory warnings
memory_warning_mb = 6144       # 記憶體超過 6GB 警告
memory_critical_mb = 7168      # 記憶體超過 7GB 嚴重警告

# Daily reporting
daily_report = true            # 是否每日自動報告
report_time = "18:00"          # 每日報告時間

[opencode.workflow]
# Workflow automation preferences
health_check_interval = 120    # 每 N 分鐘提醒檢查健康（0 = 關閉）
auto_backup = true             # 每次啟動時自動備份 sessions
backup_keep_days = 30          # 保留 N 天的備份
warn_multi_instance = true     # 檢測到多實例時警告

[opencode.worklog]
# Work log settings
dir = ".worklog"               # 工作日誌目錄
auto_backup = true             # 是否備份到 git（如果有）

# ==============================================================================
# Usage Tips
# ==============================================================================
#
# 當機頻率高時：
#   [opencode.cleanup]
#   max_sessions = 15
#   aggressive_mode = true
#   aggressive_keep = 8
#
# 當機頻率低時：
#   [opencode.cleanup]
#   max_sessions = 30
#   aggressive_mode = false
#
# 記憶體充足時：
#   [opencode.monitor]
#   memory_warning_mb = 8192
#
# 快速執行需求：
#   [opencode.workflow]
#   health_check_interval = 0
#   auto_backup = false
#

# ==============================================================================
# 已知限制 | Known Limitations
# ==============================================================================
#
# 多實例限制 | Multiple Instance Limitation:
#   VSCode OpenCode Extension 所有實例共用單一資料庫
#   (~/.local/share/opencode/opencode.db)
#   
#   同時執行多個實例會導致：
#   - 資料庫衝突
#   - 隨機崩潰
#   - Session 遺失
#
#   建議工作流程：
#   1. 一次只開一個專案的 VSCode
#   2. 使用 ./scripts/wl 做本地工作記錄（不依賴 OpenCode sessions）
#   3. 頻繁 commit（30-60 分鐘一次）
#
#   詳細說明：docs/MULTI_INSTANCE_LIMITATION.md
#

# ==============================================================================
# Service Capabilities Detection
# ==============================================================================
# Declare which services are available, unsupported, or require alternatives
# This prevents OpenCode from attempting to use unavailable services
#
# Based on: ADR 0008 - OpenCode Configuration Strategy

[services]
# Explicitly declare unsupported services
# These will trigger graceful fallback with helpful error messages
unsupported = [
  "google-search",   # Requires GCP Gemini API enablement (see error: SERVICE_DISABLED)
  "google_search",   # Alternative naming
]

# Service capability matrix - maps functionality to available tools
[services.capabilities]
web_search = [
  "websearch_web_search_exa",  # Primary: Exa web search (clean, LLM-optimized)
  "webfetch",                   # Fallback: Direct URL fetch
]
code_search = [
  "grep_app_searchGitHub",      # Search public GitHub repositories
]
documentation = [
  "context7_query-docs",        # Query official documentation via Context7
  "context7_resolve-library-id", # Resolve library IDs for Context7
]

# Fallback behavior when service unavailable
[services.fallback]
# Mode options:
#   - "suggest": Show alternatives, let AI/user decide (default)
#   - "auto": Automatically use first available alternative
#   - "fail": Stop with error message (strict mode)
mode = "suggest"

# Log failed service call attempts for debugging
log_attempts = true

# Show detailed reason for service unavailability
show_reason = true

# ==============================================================================
# Usage Examples
# ==============================================================================
#
# When AI attempts google-search:
#   1. Check config.toml [services.unsupported]
#   2. Find "google-search" in list
#   3. Look up alternatives in [services.capabilities.web_search]
#   4. Suggest: "Service 'google-search' unavailable. Using 'websearch_web_search_exa' instead."
#
# To add new unsupported service:
#   [services]
#   unsupported = [
#     "google-search",
#     "my-new-service",  # Add here
#   ]
#
#   [services.capabilities]
#   my_functionality = ["alternative-tool-1", "alternative-tool-2"]
#

# ==============================================================================
# Project Type & Features Configuration (2.0.0+)
# ==============================================================================
# Config-driven module system - determines which documentation modules load

[project]
# Project type determines which domain-specific modules load
type = "fullstack"  # frontend | backend | fullstack | cli | library | academic | documentation | translation | other

# Project features determine which feature modules load
features = [
  # Software Development Features
  # "api",        # API_DESIGN.md
  # "database",   # DATABASE_CONVENTIONS.md
  # "auth",       # AUTH_IMPLEMENTATION.md
  # "i18n",       # I18N_GUIDE.md
  # "realtime",   # REALTIME_PATTERNS.md
  # "upload",     # FILE_HANDLING.md
  
  # Academic/Documentation Features
  # "citation",     # CITATION_MANAGEMENT.md
  # "literature",   # LITERATURE_REVIEW.md
  # "translation",  # TRANSLATION_GUIDE.md
]

# Quality requirements determine which quality modules load
quality = [
  # "performance",   # PERFORMANCE_OPTIMIZATION.md
  # "accessibility", # ACCESSIBILITY.md
  # "production",    # PRODUCTION_READINESS.md
]

# ==============================================================================
# Academic Project Settings (2.0.0+)
# ==============================================================================
# Only applies when project.type = "academic"

[academic]
# Citation style for academic writing
citation_style = "APA"  # APA | MLA | Chicago | IEEE | Vancouver

# Academic field
field = "computer_science"  # computer_science | social_science | humanities | natural_science | medicine

# Document languages (for bilingual academic work)
primary_language = "zh-TW"
secondary_language = "en-US"

# ==============================================================================
# GitHub Settings (2.0.0+)
# ==============================================================================

[github]
# Generate multilingual PR template
use_pr_template = true  # Generates .github/PULL_REQUEST_TEMPLATE.md

# PR template language follows [i18n].primary_locale
# Template files: .scaffolding/templates/pr/PULL_REQUEST_TEMPLATE.{lang}.md

# ==============================================================================
# Documentation Modules Configuration (2.0.0+)
# ==============================================================================

[modules]
# Force-enable modules (regardless of project.type)
always_enabled = [
  "STYLE_GUIDE",
  "TERMINOLOGY",
  "GIT_WORKFLOW",
  "TESTING_STRATEGY",
  "SECURITY_CHECKLIST",
]

# Manually enable additional modules
manual_enabled = []

# Manually disable modules (even if project.type suggests them)
manual_disabled = []

# ==============================================================================
# Terminology System (2.0.0+)
# ==============================================================================

[terminology]
# Terminology loading priority (highest to lowest)
# When same term exists in multiple files, which one wins?
priority = ["project", "domain", "common"]  # project > domain > common

# Terminology sources
# - project: .agents/terminology/custom.md (user-defined)
# - domain: .scaffolding/terminology/{domain}/*.md (software/academic/documentation)
# - common: .scaffolding/terminology/terminology.md (universal terms)

