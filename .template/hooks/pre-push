#!/bin/bash
# Pre-push hook to ensure version is bumped before pushing to main

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Get the remote name and URL
remote="$1"
url="$2"

# Read from stdin to get the list of refs being pushed
while read local_ref local_sha remote_ref remote_sha
do
    # Only check pushes to main branch
    if [[ "$remote_ref" == "refs/heads/main" ]]; then
        echo -e "${YELLOW}⚠️  Pushing to main branch - checking version...${NC}"
        
        # Get current version
        if [ -f ".template/VERSION" ]; then
            CURRENT_VERSION=$(cat .template/VERSION)
        else
            echo -e "${RED}❌ Error: .template/VERSION file not found${NC}"
            exit 1
        fi
        
        # Get the latest tag version (if exists)
        LATEST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "v0.0.0")
        LATEST_TAG_VERSION=${LATEST_TAG#v}  # Remove 'v' prefix
        
        # Check if version has been bumped
        if [ "$CURRENT_VERSION" == "$LATEST_TAG_VERSION" ]; then
            echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo -e "${RED}❌ VERSION NOT UPDATED!${NC}"
            echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            echo ""
            echo -e "Current version: ${YELLOW}$CURRENT_VERSION${NC}"
            echo -e "Latest tag:      ${YELLOW}$LATEST_TAG${NC}"
            echo ""
            echo -e "${YELLOW}You must bump the version before pushing to main!${NC}"
            echo ""
            echo "Quick fix:"
            echo "  1. Run one of these commands:"
            echo "     ${GREEN}./.template/scripts/bump-version.sh patch${NC}   # For bug fixes"
            echo "     ${GREEN}./.template/scripts/bump-version.sh minor${NC}   # For new features"
            echo "     ${GREEN}./.template/scripts/bump-version.sh major${NC}   # For breaking changes"
            echo ""
            echo "  2. Or manually:"
            echo "     ${GREEN}echo \"X.Y.Z\" > .template/VERSION${NC}"
            echo "     ${GREEN}git add .template/VERSION VERSION CHANGELOG.md README.md${NC}"
            echo "     ${GREEN}git commit -m \"chore(release): bump version to X.Y.Z\"${NC}"
            echo "     ${GREEN}git tag -a vX.Y.Z -m \"Release vX.Y.Z\"${NC}"
            echo ""
            echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
            exit 1
        fi
        
        # Check if there's a corresponding git tag
        if ! git rev-parse "v$CURRENT_VERSION" >/dev/null 2>&1; then
            echo -e "${YELLOW}⚠️  Warning: No git tag found for v$CURRENT_VERSION${NC}"
            echo "Consider creating a tag:"
            echo "  ${GREEN}git tag -a v$CURRENT_VERSION -m \"Release v$CURRENT_VERSION\"${NC}"
            echo ""
            read -p "Continue anyway? (y/N): " confirm
            if [[ ! $confirm =~ ^[Yy]$ ]]; then
                echo "Push cancelled."
                exit 1
            fi
        fi
        
        echo -e "${GREEN}✅ Version check passed: $CURRENT_VERSION${NC}"
    fi
done

exit 0
